NEXT_PUBLIC_APP_URL=http://localhost:3000

# Local host path. If Postgres runs in Docker and the app runs on the host, expose db as localhost:5433.
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/innerscript

# Optional AI features. Core journaling must work without this key.
OPENAI_API_KEY=
ANALYSIS_ENABLED=false
ANALYSE_MIN_WORD_COUNT=50
